# PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/db?sslmode=require"
PRISMA_CONNECTION_LIMIT=1

# Auth/session. Obrigatorio em producao.
AUTH_SECRET="generate-a-strong-random-secret"

# Mercado Pago. Use TEST-... em sandbox e APP_USR-... em producao.
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET="generate-a-strong-random-secret"

# Crons externos e Vercel Cron. A Vercel envia Authorization: Bearer <CRON_SECRET> quando esta variavel existe.
CRON_SECRET="generate-a-strong-random-secret"

# Email. Sem RESEND_API_KEY, lembretes ficam apenas dentro do sistema.
RESEND_API_KEY=
FROM_EMAIL=noreply@seudominio.com.br
